# Copy this file to .desk-sprite.env and update the values for your machine.
# Never commit .desk-sprite.env: it may contain a gateway token.

OPENCLAW_ROOT="/absolute/path/to/.openclaw"
OPENCLAW_GATEWAY_URL="ws://127.0.0.1:18789"
# OPENCLAW_GATEWAY_TOKEN="replace-with-your-local-token"
# OPENCLAW_ACTIVE_WINDOW_SECONDS=20
# OPENCLAW_START_SCRIPT="/absolute/path/to/your/start-openclaw.command"
